---
// Lucide-style line icons + social glyphs, ported from the design kit (site.jsx).
// Usage: <Icon name="search" size={19} />
const { name, size = 24, class: className, ...rest } = Astro.props;
const s = String(size);
const stroke = { viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', 'stroke-linecap': 'round', 'stroke-linejoin': 'round' };
---
{name === 'search' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.85" {...rest}><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>}
{name === 'menu' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.85" {...rest}><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>}
{name === 'x' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.85" {...rest}><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>}
{name === 'arrow' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.85" {...rest}><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>}
{name === 'arrowUR' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.85" {...rest}><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>}
{name === 'globe' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.75" {...rest}><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/></svg>}
{name === 'book' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.75" {...rest}><path d="M2 4h7a3 3 0 0 1 3 3v13a2.5 2.5 0 0 0-2.5-2.5H2z"/><path d="M22 4h-7a3 3 0 0 0-3 3v13a2.5 2.5 0 0 1 2.5-2.5H22z"/></svg>}
{name === 'users' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.75" {...rest}><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
{name === 'file' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.75" {...rest}><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>}
{name === 'building' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.75" {...rest}><rect x="4" y="3" width="16" height="18" rx="1.5"/><path d="M9 8h.01M15 8h.01M9 12h.01M15 12h.01M9 21v-4h6v4"/></svg>}
{name === 'flask' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.75" {...rest}><path d="M9 3h6M10 3v6.5L5 18a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 18l-5-8.5V3"/><line x1="7.5" y1="14" x2="16.5" y2="14"/></svg>}
{name === 'download' && <svg width={s} height={s} class={className} {...stroke} stroke-width="1.85" {...rest}><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>}
{name === 'twitter' && <svg width={s} height={s} class={className} viewBox="0 0 24 24" fill="currentColor" {...rest}><path d="M18.9 1.2h3.7l-8 9.1 9.4 12.5h-7.4l-5.8-7.6-6.6 7.6H.5l8.6-9.8L0 1.2h7.6l5.2 6.9zM17.6 20.6h2L6.5 3.2h-2.2z"/></svg>}
{name === 'linkedin' && <svg width={s} height={s} class={className} viewBox="0 0 24 24" fill="currentColor" {...rest}><path d="M20.45 20.45h-3.56v-5.57c0-1.33 0-3.04-1.85-3.04s-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56zM22.22 0H1.77A1.75 1.75 0 0 0 0 1.73v20.54A1.75 1.75 0 0 0 1.77 24h20.45A1.76 1.76 0 0 0 24 22.27V1.73A1.76 1.76 0 0 0 22.22 0z"/></svg>}
{name === 'rss' && <svg width={s} height={s} class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" {...rest}><path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1.5" fill="currentColor"/></svg>}
