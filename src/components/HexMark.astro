---
// Molecular three-hexagon brand glyph. Recolors via currentColor.
const { class: className } = Astro.props;
---
<svg class={className} viewBox="0 0 48 48" fill="none" aria-hidden="true">
  <g stroke="currentColor" stroke-width="2" stroke-linejoin="round">
    <polygon points="24,4 33,9.5 33,20.5 24,26 15,20.5 15,9.5"/>
    <polygon points="13,22 22,27.5 22,38.5 13,44 4,38.5 4,27.5"/>
    <polygon points="35,22 44,27.5 44,38.5 35,44 26,38.5 26,27.5"/>
  </g>
  <g fill="currentColor"><circle cx="24" cy="15" r="2.4"/><circle cx="13" cy="33" r="2.4"/><circle cx="35" cy="33" r="2.4"/></g>
</svg>
