---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleView from '../components/ArticleView.astro';
import JournalHomeView from '../components/JournalHomeView.astro';
import InfoView from '../components/InfoView.astro';
import { getJournal } from '../lib/journals.js';

import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  // Read generated entries from disk rather than import.meta.glob: at ~9k+ files
  // the eager glob bundles into one module and overflows the call stack.
  const PAGES_DIR = path.join(process.cwd(), 'src', 'data', 'generated', 'pages');
  function walk(dir) {
    const out = [];
    if (!fs.existsSync(dir)) return out;
    for (const name of fs.readdirSync(dir)) {
      const p = path.join(dir, name);
      const st = fs.statSync(p);
      if (st.isDirectory()) out.push(...walk(p));
      else if (name.endsWith('.json')) out.push(p);
    }
    return out;
  }
  const entries = walk(PAGES_DIR).map((f) => JSON.parse(fs.readFileSync(f, 'utf-8')));

  // Group articles by journal for journal-home listings.
  const byJournal = {};
  for (const e of entries) {
    if (e.type === 'article' && !e.alias) {
      (byJournal[e.journal] ||= []).push(e);
    }
  }
  for (const k of Object.keys(byJournal)) {
    byJournal[k].sort((a, b) => (b.refdomains || 0) - (a.refdomains || 0));
    byJournal[k] = byJournal[k].slice(0, 60); // cap related list passed as props
  }

  function yearOf(d) { const mm = String(d || '').match(/(\d{4})/); return mm ? mm[1] : ''; }

  return entries.map((entry) => {
    let related = [];
    if (entry.type === 'journal-home') {
      related = (byJournal[entry.journal] || []).map((a) => ({
        slug: a.slug,
        title: a.meta?.title || a.slug,
        authors: (a.meta?.authors || []).slice(0, 6).join(', ') + ((a.meta?.authors || []).length > 6 ? ', et al.' : ''),
        type: (a.meta?.section || '').replace(/\b\w/g, (c) => c.toUpperCase()),
        vol: a.meta?.volume,
        issue: a.meta?.issue,
        date: yearOf(a.meta?.date),
        doi: a.meta?.doi,
        refdomains: a.refdomains || 0,
      }));
    }
    return { params: { slug: entry.slug }, props: { entry, related } };
  });
}

const { entry, related } = Astro.props;
const j = getJournal(entry.journal);

let title, description, jsonld;
if (entry.type === 'article') {
  const m = entry.meta || {};
  title = m.title;
  // meta description from abstract first sentence, then summary, stripped of tags
  const absText = (entry.abstractHtml || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  const sumText = (entry.summaryHtml || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  description = (absText || sumText) ? (absText || sumText).slice(0, 280) : `${m.title} — ${m.journalTitle || (j ? j.name : '')}${m.volume ? `, volume ${m.volume}` : ''}.`;
  jsonld = {
    '@context': 'https://schema.org',
    '@type': 'ScholarlyArticle',
    headline: m.title,
    author: (m.authors || []).map((name) => ({ '@type': 'Person', name })),
    datePublished: m.date,
    isPartOf: { '@type': 'Periodical', name: m.journalTitle || (j ? j.name : '') },
    volumeNumber: m.volume,
    issueNumber: m.issue,
    pagination: m.firstpage,
    identifier: m.doi ? { '@type': 'PropertyValue', propertyID: 'DOI', value: m.doi } : undefined,
    description: (absText || sumText) ? (absText || sumText).slice(0, 5000) : undefined,
    url: entry.canonical,
  };
} else if (entry.type === 'journal-home') {
  title = j ? j.name : entry.journal;
  description = j ? j.tagline : `${entry.journal} — archived research from the Society for General Microbiology.`;
} else {
  title = entry.title || 'Information';
  description = (entry.bodyHtml || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 240)
    || `${title} — an archived page from the SGM Journals research archive.`;
}

const navActive = 'Journals';
// Thin pages (explicit stubs, or articles where only citation metadata was
// recovered) stay reachable (200 + canonical, so link equity still flows) but
// are not indexed.
const thin = entry.type === 'article' && !entry.bodyHtml && !entry.abstractHtml && !entry.summaryHtml;
const robots = (entry.stub || thin) ? 'noindex,follow' : undefined;
---
<BaseLayout title={title} description={description} canonical={entry.canonical} navActive={navActive} jsonld={jsonld} robots={robots}>
  {entry.type === 'article' && <ArticleView entry={entry} />}
  {entry.type === 'journal-home' && <JournalHomeView entry={entry} articles={related} />}
  {(entry.type === 'info-page' || entry.type === 'other' || entry.type === 'subscriptions' || entry.type === 'toc/issue') && <InfoView entry={entry} />}
</BaseLayout>
