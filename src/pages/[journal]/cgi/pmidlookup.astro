---
// Client-side resolver for legacy /<journal>/cgi/pmidlookup?pmid=NNNN endpoints.
// These old URLs only ever 302'd to an article and were never crawled, so there
// is no source page. We resolve PMID -> on-site article where the PMID was found
// while parsing the archive; otherwise we fall back to the PubMed record so the
// inbound link always lands somewhere meaningful.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import pmid from '../../../data/pmidlookup.json';
import { JOURNAL_ORDER, getJournal } from '../../../lib/journals.js';

export function getStaticPaths() {
  // Build the resolver under every journal prefix (the host redirect adds it).
  return JOURNAL_ORDER.map((journal) => ({ params: { journal } }));
}

const { journal } = Astro.params;
const j = getJournal(journal);
const resolvedMap = pmid.resolved || {};
const description = 'Resolving a PubMed identifier to its article.';
---
<BaseLayout title="Looking up article" description={description} robots="noindex,follow">
  <div class="sgm-container page-body" style="text-align:center;max-width:560px">
    <h1 class="sgm-h2" style="font-family:var(--font-display)">Looking up article…</h1>
    <p class="sgm-body" style="color:var(--text-muted);margin-top:var(--sp-3)">
      Redirecting you to the article for this PubMed identifier.
    </p>
    <p id="pmid-fallback" style="margin-top:var(--sp-5)">
      <a id="pmid-link" class="sgm-btn sgm-btn--primary" href={j ? `/${j.code}/` : '/'}>Continue to {j ? j.name : 'the journals'}</a>
    </p>
  </div>
  <script type="application/json" id="pmid-map" set:html={JSON.stringify(resolvedMap)}></script>
  <script is:inline>
    (function () {
      var map = {};
      try { map = JSON.parse(document.getElementById('pmid-map').textContent || '{}'); } catch (e) {}
      var params = new URLSearchParams(location.search);
      var pmid = params.get('pmid');
      var dest = null;
      if (pmid && map[pmid]) dest = map[pmid];
      else if (pmid) dest = 'https://pubmed.ncbi.nlm.nih.gov/' + encodeURIComponent(pmid) + '/';
      if (dest) {
        var link = document.getElementById('pmid-link');
        if (link) { link.setAttribute('href', dest); link.textContent = 'Continue to the article'; }
        location.replace(dest);
      }
    })();
  </script>
</BaseLayout>
