al,helvetica\">Interferons and viruses: an interplay between induction, signalling, antiviral responses and virus countermeasures</font></th>\n    </tr>\n    <tr>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td><font size=\"-1\" face=\"arial,helvetica\">J. Gen. Virol. Jan 01, 2008; 89: 1-47.<br>\n      (In \"REVIEW\")&nbsp;&nbsp; <nobr><a href=\"/vir/cgi/content/short/89/1/1\"><font size=\"-1\" face=\"arial,helvetica\">[Abstract]</font></a> &nbsp;&nbsp;&nbsp; <a href=\"/vir/cgi/content/full/89/1/1\"><font size=\"-1\" face=\"arial,helvetica\">[Full Text]</font></a> <font size=\"-2\" face=\"arial,helvetica\"></font>&nbsp;&nbsp;&nbsp; <a href=\"/vir/cgi/reprint/89/1/1\"><font size=\"-1\" face=\"arial,helvetica\">[PDF]</font></a> <font size=\"-2\" face=\"arial,helvetica\"></font></nobr></font></td>\n    </tr>\n    <tr>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n    </tr>\n    <tr>\n      <td>&nbsp;</td>\n    </tr>\n    <tr>\n      <td align=\"right\" valign=\"top\"><font size=\"-1\" face=\"arial,helvetica\">2.</font>&nbsp;</td>\n      <td colspan=\"2\"><font size=\"-1\" face=\"arial,helvetica\">Sonia Van Dooren, Vedapuri Shanmugam, Vinod Bhullar, Bharat Parekh, Anne-Mieke Vandamme, Walid Heneine, William M. Switzer</font></td>\n    </tr>\n    <tr>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <th align=\"left\"><font size=\"-1\" face=\"arial,helvetica\">Identification in gelada baboons (<i>Theropithecus gelada</i>) of a distinct simian T-cell lymphotropic virus type 3 with a broad range of Western blot reactivity</font></th>\n    </tr>\n    <tr>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td><font size=\"-1\" face=\"arial,helvetica\">J. Gen. Virol. Feb 01, 2004; 85: 507-519.<br>\n      (In \"ANIMAL: RNA VIRUSES\")&nbsp;&nbsp; <nobr><a href=\"/vir/cgi/content/short/85/2/507\"><font size=\"-1\" face=\"arial,helvetica\">[Abstract]</font></a> &nbsp;&nbsp;&nbsp; <a href=\"/vir/cgi/content/full/85/2/507\"><font size=\"-1\" face=\"arial,helvetica\">[Full Text]</font></a> <font size=\"-2\" face=\"arial,helvetica\"></font>&nbsp;&nbsp;&nbsp; <a href=\"/vir/cgi/reprint/85/2/507\"><font size=\"-1\" face=\"arial,helvetica\">[PDF]</font></a> <font size=\"-2\" face=\"arial,helvetica\"></font></nobr></font></td>\n    </tr>\n    <tr>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n    </tr>\n    <tr>\n      <td>&nbsp;</td>\n    </tr>\n    <tr>\n      <td align=\"right\" valign=\"top\"><font size=\"-1\" face=\"arial,helvetica\">3.</font>&nbsp;</td>\n      <td colspan=\"2\"><font size=\"-1\" face=\"arial,helvetica\">Priti Kumar, Venkatramana D. Krishna, Paramadevanapalli Sulochana, Gejjehalli Nirmala, Maganti Haridattatreya, Vijaya Satchidanandam</font></td>\n    </tr>\n    <tr>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <td nowrap=\"\"><img alt=\" \" hspace=\"3\" width=\"19\" height=\"11\" src=\"/icons/spacer.gif\"></td>\n      <th align=\"left\"><font size=\"-1\" face=\"arial,helvetica\">Cell-mediated immune responses in healthy children with a history of subclinical infection with <i>Japanese