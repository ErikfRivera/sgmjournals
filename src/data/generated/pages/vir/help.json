{"type":"info-page","slug":"vir/help","journal":"vir","canonical":"https://www.sgmjournals.org/vir/help","title":"J Gen Virol -- Help","bodyHtml":"<nobr><map name=\"home_button\" id=\"home_button\">\n    </map></nobr><nobr></nobr><nobr></nobr>\n    <area shape=\"rect\" coords=\"57,22,110,40\" href=\"/help/\">\n    <nobr></nobr>\n    <area shape=\"rect\" coords=\"0, 0,110,40\" href=\"/\">\n   <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/\"><img border=\"0\" width=\"220\" height=\"44\" alt=\"J Gen Virol\" src=\"/icons/banner/title.gif\"></a><br>\n  <nobr></nobr>\n  <table cellpadding=\"2\" cellspacing=\"2\" width=\"450\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">HOME</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#E1E1E1\" nowrap=\"\"><font size=\"-2\" color=\"#000000\" face=\"arial,helvetica\">HELP</font></td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/cgi/feedback\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">FEEDBACK</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/subscriptions\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SUBSCRIPTIONS</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/contents-by-date.0.shtml\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">ARCHIVE</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/search.shtml\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SEARCH</font></a>\n      </td>\n      <td width=\"75\" nowrap=\"\"></td>\n    </tr>\n  </tbody></table>\n  <hr width=\"450\" align=\"left\" noshade=\"\">\n  <p><font size=\"+2\" face=\"arial,helvetica\"><strong>Help with Journal of General Virology Online</strong></font></p>\n  <dl>\n    <dd>\n      <img width=\"9\" height=\"11\" border=\"0\" src=\"/icons/toc/rarrowsm.gif\"><strong><font size=\"-1\" face=\"arial,helvetica\">Subscription Information</font></strong>\n      <dl>\n        <dd>\n          Help &amp; Services for <a href=\"/vir/subscriptions/\">Print and Online Subscribers</a>\n        </dd>\n        <dd>\n          Help with <a href=\"/vir/help/ip-help.dtl\">IP Addresses</a>\n        </dd>\n      </dl>\n      <p></p>\n    </dd>\n    <dd>\n      <img width=\"9\" height=\"11\" border=\"0\" src=\"/icons/toc/rarrowsm.gif\"><strong><font size=\"-1\" face=\"arial,helvetica\">Features of Journal of General Virology Online</font></strong>\n      <dl>\n        <dd>\n          List of <a href=\"/vir/help/features.dtl\">Major Features</a>\n        </dd>\n        <dd>\n          Help with <a href=\"/vir/help/search_help.dtl\">Searching</a>\n        </dd>\n        <dd>\n          Help with <a href=\"/vir/help/print_help.dtl\">Printing</a> and <a href=\"/vir/help/pdf-faq.dtl\">PDFs</a>\n        </dd>\n      </dl>\n      <p></p>\n    </dd>\n    <dd>\n      <img width=\"9\" height=\"11\" border=\"0\" src=\"/icons/toc/rarrowsm.gif\"><strong><font size=\"-1\" face=\"arial,helvetica\">Journal of General Virology Online's <a href=\"/vir/tips/\">Tips for Better Web Browsing</a></font></strong>\n      <p></p>\n    </dd>\n    <dd>\n      <img width=\"9\" height=\"11\" border=\"0\" src=\"/icons/toc/rarrowsm.gif\"><strong><font size=\"-1\" face=\"arial,helvetica\">Frequently Asked Questions</font></strong>\n      <dl>\n        <dd>\n          <a href=\"/vir/misc/faq.shtml\">About Journal of General Virology Online</a>\n        </dd>\n        <dd>\n          About Our Use of <a href=\"/vir/help/aboutcookies.dtl\">\"Cookies\" and your Privacy</a>\n        </dd>\n        <dd>\n          Help with <a href=\"/vir/help/cookie.dtl\">\"Auto Sign In\"</a> and <a href=\"/vir/help/uncookie.dtl\">\"Sign Out\"</a>\n        </dd>\n        <dd>\n          About <a href=\"/vir/help/pdf-faq.dtl\">PDFs</a>\n        </dd>\n        <dd>\n          \"Why doesn't J Gen Virol have <a href=\"/vir/tips/stale.dtl\">the current issue online</a>?\"\n        </dd>\n        <dd>\n          How To <a href=\"/vir/help/netscape_tips.dtl\">Use Netscape or Internet Explorer Effectively</a>\n        </dd>\n        <dd>\n          <a href=\"/vir/help/browser.dtl\">Web Browser Requirements</a> for Journal of General Virology Online\n        </dd>\n        <dd>\n          Minimum <a href=\"/vir/help/hardware.dtl\">Hardware Requirements</a> for Journal of General Virology Online\n        </dd>\n      </dl>\n      <p></p>\n    </dd>\n    <dd>\n      <img width=\"9\" height=\"11\" border=\"0\" src=\"/icons/toc/rarrowsm.gif\"><strong><font size=\"-1\" face=\"arial,helvetica\">Is the site too slow?</font></strong>\n      <dl>\n        <dd>\n          Journal of General Virology Online's <a href=\"/vir/help/slow.dtl\">Site for Readers Outside of USA/Canada</a>\n        </dd>\n        <dd>\n          <a href=\"/vir/help/slow-tips.dtl\">Speed Tips for Users in USA/Canada</a>\n        </dd>\n        <dd>\n          How to <a href=\"/vir/help/offline.dtl\">Read Journal of General Virology Online \"Offline\"</a>\n        </dd>\n      </dl>\n      <p></p>\n    </dd>\n    <dd>\n      <img width=\"9\" height=\"11\" border=\"0\" src=\"/icons/toc/rarrowsm.gif\"><strong><font size=\"-1\" face=\"arial,helvetica\">How to Obtain Graphics Viewing Software:</font></strong>\n      <dl>\n        <dd>\n          For <a href=\"/vir/help/software-mac.dtl\">Macintoshes</a>\n        </dd>\n        <dd>\n          For <a href=\"/vir/help/software-win.dtl\">Windows PCs</a>\n        </dd>\n        <dd>\n          For <a href=\"/vir/help/software-unix.dtl\">Unix workstations or X-terminals</a>\n        </dd>\n      </dl>\n    </dd>\n  </dl>\n  <p>If you don't find the answer you need, please let us know via the <strong><a href=\"/vir/cgi/feedback\">Feedback</a></strong> form.</p>\n  <p></p>\n  <table cellpadding=\"10\" cellspacing=\"1\" border=\"0\" width=\"450\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"middle\">\n        <hr noshade=\"\" align=\"left\" size=\"1\">\n        <font color=\"#007E18\" size=\"+2\"><strong>Please Note:</strong></font><br>\n        We support the current production version, and the production version just previous, of the following popular web browsers: Netscape's <nobr><strong>Communicator</strong></nobr>, <nobr>Microsoft's <strong>Internet Explorer *</strong></nobr>, and Lynx. (Due to the graphical nature of the content in Journal of General Virology, we recommend Lynx only for those who have no other way to connect to the Web.)\n        <p><strong>* <font size=\"+1\" color=\"#007E18\">IMPORTANT NOTE: You must install a patch from Microsoft in order for Microsoft's Internet Explorer 5.0 for Windows to work with Journal of General Virology Online properly.</font></strong> There was a problem in the new version of Explorer (5.0) that caused some links to not work.</p>\n        <p><strong><a href=\"/vir/help/browser.dtl\">How to make sure you have the most current version of your web browser</a></strong></p>\n        <p>For the best and most reliable service, we recommend that America Online Browser users upgrade to one of the above browsers. We cannot guarantee that all features of Journal of General Virology Online will work while using the AOL Browser.</p>\n        <p>All help text on this site is written for the most recent browser versions. We cannot promise that all features of Journal of General Virology Online will work properly with every other version of every other browser.</p>\n      </td>\n    </tr>\n  </tbody></table>\n  <p></p>\n  <hr noshade=\"\" align=\"left\" width=\"450\">\n  <table cellpadding=\"2\" cellspacing=\"2\" width=\"450\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">HOME</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#E1E1E1\" nowrap=\"\"><font size=\"-2\" color=\"#000000\" face=\"arial,helvetica\">HELP</font></td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/cgi/feedback\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">FEEDBACK</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/subscriptions\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SUBSCRIPTIONS</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/contents-by-date.0.shtml\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">ARCHIVE</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/search.shtml\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SEARCH</font></a>\n      </td>\n      <td width=\"75\" nowrap=\"\"></td>\n    </tr>\n  </tbody></table>\n  <table cellpadding=\"1\" cellspacing=\"2\" width=\"375\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/ijs/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">INT J SYST BACTERIOL</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">MICROBIOLOGY</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#E1E1E1\" nowrap=\"\"><font size=\"-2\" color=\"#000000\" face=\"arial,helvetica\">J GEN VIROL</font></td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#007E18\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">ALL SGM JOURNALS</font></a>\n      </td>\n    </tr>\n  </tbody></table><font size=\"-1\"><strong><a target=\"_top\" href=\"/vir/misc/terms.shtml\">Copyright © 1999 by the Society for General Microbiology.</a></strong></font>"}