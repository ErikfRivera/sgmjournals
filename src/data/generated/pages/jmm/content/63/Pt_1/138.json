{"type":"article","slug":"jmm/content/63/Pt_1/138","journal":"jmm","canonical":"https://www.sgmjournals.org/jmm/content/63/Pt_1/138","meta":{"title":"Meningoencephalitis due to Gemella haemolysans","authors":["Benjamin T. Galen","David B. Banach","Melissa R. Gitman","Terence K. Trow"],"journalTitle":"Journal of Medical Microbiology","journalAbbrev":"J Med Microbiol","volume":"63","issue":"Pt 1","firstpage":"138","lastpage":"139","date":"01/01/2014","doi":"10.1099/jmm.0.063347-0","issn":["0022-2615","1473-5644"],"pmid":"24072762","mjid":"medmicro;63/Pt_1/138","section":"Case reports","abstractUrl":"http://jmm.sgmjournals.org/content/63/Pt_1/138.abstract","fulltextUrl":"http://jmm.sgmjournals.org/content/63/Pt_1/138.full","pdfUrl":"http://jmm.sgmjournals.org/content/63/Pt_1/138.full.pdf","publicUrl":"http://jmm.sgmjournals.org/content/63/Pt_1/138"},"abstractHtml":"<p id=\"p-1\"><em>Gemella haemolysans</em> is an uncommon but described cause of invasive disease in humans. We report a case of meningitis due to <em>G. haemolysans</em> that did not grow in cerebrospinal fluid culture, demonstrating a potential role for direct 16S rRNA gene PCR and sequencing in culture-negative cerebrospinal fluid when bacterial meningitis is suspected.</p>","bodyHtml":"<dl id=\"def-list-1\">\n          <dt class=\"def-list-title\">Abbreviations:</dt>\n          <dd></dd>\n          <dt id=\"def-item-1\">CSF<span class=\"def-item-dt-sep\"></span></dt>\n          <dd>cerebrospinal fluid</dd>\n        </dl>","referencesHtml":"","affiliationsHtml":"<li class=\"aff\">\n\n              <address>\n                <sup>1</sup>Department of Internal Medicine, Albert Einstein College of Medicine, Bronx, NY, USA\n              </address>\n            </li>\n            <li class=\"aff\">\n\n              <address>\n                <sup>2</sup>Department of Internal Medicine, Yale University School of Medicine, New Haven, CT, USA\n              </address>\n            </li>\n            <li class=\"aff\">\n\n              <address>\n                <sup>3</sup>Pathology and Laboratory Medicine, Yale University School of Medicine, New Haven, CT, USA\n              </address>\n            </li>\n            <li class=\"aff\">\n\n              <address>\n                <sup>4</sup>Section of Pulmonary, Critical Care and Sleep Medicine, Yale School of Medicine, New Haven, CT, USA\n              </address>\n            </li>","correspHtml":"<li class=\"corresp\" id=\"corresp-1\"><strong>Correspondence</strong><br>\n            Benjamin T. Galen <span class=\"em-link\"><span class=\"em-addr\">bgalen{at}montefiore.org</span></span></li>","pdfPath":null,"refdomains":0}