{"type":"info-page","slug":"mic/index.dtl","journal":"mic","canonical":"https://www.sgmjournals.org/mic/index.dtl","title":"Microbiology Manuscript Processing System","bodyHtml":"<div class=\"bp_signin_content_base\">\n    <table class=\"bp_signin_banner\" cellpadding=\"0\">\n      <tbody><tr>\n        <td style=\"padding:0px;margin:0px;text-align:left;\"><img alt=\"Microbiology\" src=\"/icons/misc/banner_corners_transparency_short.gif\"></td>\n      </tr>\n      <tr>\n        <td style=\"border-left:1px solid #999;border-right:1px solid #999;\" height=\"76\"></td>\n      </tr>\n    </tbody></table>\n    <table class=\"bp_signin_link_strip_base\" cellpadding=\"0\" cellspacing=\"0\">\n      <tbody><tr>\n        <td align=\"center\" class=\"bp_dark_button\" style=\"width:33%;white-space:nowrap\">\n          <a class=\"bp_dark_button\" href=\"/mic/cgi/registration\"><b>Create a new account</b></a>\n        </td>\n        <td align=\"center\" class=\"bp_dark_button\" style=\"width:34%;white-space:nowrap\">\n          <a class=\"bp_dark_button\" href=\"/mic/cgi/lostPassword\">I have forgotten my password</a>\n        </td>\n        <td align=\"center\" class=\"bp_dark_button\" style=\"width:33%;white-space:nowrap\">\n          <a class=\"bp_dark_button\" href=\"/mic/help/faq.dtl?faqarea=security\">Security FAQ</a>\n        </td>\n      </tr>\n    </tbody></table>\n    <div class=\"bp_signin_form_section_base\">\n      <form action=\"/cgi/login\" method=\"post\">\n        <div class=\"bp_signin_welcome_message_wrap\">\n          <input type=\"hidden\" name=\"assocredirect\" value=\"/submission/editassoc?fromSignin=true\">\n          <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n            <tbody><tr style=\"height:100%\">\n              <td align=\"right\">\n                <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" height=\"100%\">\n                  <tbody><tr>\n                    <td class=\"bp_tl_ccc\"></td>\n                  </tr>\n                  <tr>\n                    <td class=\"bp_side_ccc\">&nbsp;</td>\n                  </tr>\n                  <tr>\n                    <td class=\"bp_bl_ccc\"></td>\n                  </tr>\n                </tbody></table>\n              </td>\n              <td width=\"550\" align=\"center\" valign=\"middle\" height=\"1\" bgcolor=\"#FFFFFF\"><span class=\"bp_signin_welcome_message\">Welcome to the Microbiology manuscript processing system.<br>\n              If this is your first time using the system please <a href=\"/mic/cgi/registration\" style=\"color:#003399\">create a new account</a>.</span></td>\n              <td>\n                <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" height=\"100%\">\n                  <tbody><tr>\n                    <td class=\"bp_tr_ccc\"></td>\n                  </tr>\n                  <tr>\n                    <td class=\"bp_side_ccc\">&nbsp;</td>\n                  </tr>\n                  <tr>\n                    <td class=\"bp_br_ccc\"></td>\n                  </tr>\n                </tbody></table>\n              </td>\n            </tr>\n          </tbody></table>\n        </div>\n        <div class=\"bp_signin_form_fields\">\n          Email: <input type=\"text\" name=\"MSTRServlet.emailAddr\" size=\"25\" maxlength=\"100\" value=\"\"> Password: <input type=\"password\" name=\"MSTRServlet.password\" size=\"15\" maxlength=\"100\" value=\"\"><br>\n          <span class=\"bp_signin_text\"><input type=\"checkbox\" name=\"remember_me\" value=\"true\"> remember my email address &nbsp;&nbsp;&nbsp;<input type=\"submit\" value=\"Sign in\" name=\"login\"> <sup>(<a href=\"/mic/cgi/lostPassword\">lost password?</a>)</sup></span>\n        </div>\n        <table class=\"bp_signin_area_lists_table\">\n          <tbody><tr>\n            <td valign=\"top\" style=\"white-space:nowrap\">\n              <input type=\"radio\" name=\"system_area\" value=\"author\" checked=\"\"> <span class=\"bp_signin_area_header\">&nbsp;Enter the <b><span style=\"color:#003399\">Author Area</span></b> to:</span>\n              <ul>\n                <li>Submit a New/Revised Manuscript</li>\n                <li>Continue a Manuscript Submission</li>\n                <li>Proof a converted manuscript</li>\n                <li>Check the Status of a Manuscript</li>\n              </ul><input type=\"radio\" name=\"system_area\" value=\"reviewer\"> <span class=\"bp_signin_area_header\">&nbsp;Enter the <b><span style=\"color:#003399\">Reviewer Area</span></b> to:</span>\n              <ul>\n                <li>Respond to a Review Request</li>\n                <li>Submit or Work on a Review</li>\n              </ul>\n            </td>\n            <td valign=\"top\" style=\"white-space:nowrap\">\n              <input type=\"radio\" name=\"system_area\" value=\"account\"> <span class=\"bp_signin_area_header\">&nbsp;Enter the <b><span style=\"color:#003399\">Personal Info Area</span></b> to:</span>\n              <ul>\n                <li>Change your Password</li>\n                <li>Update your Contact Information</li>\n                <li>Update your Availability Information</li>\n                <li>Update your Expertise Areas</li>\n              </ul><input type=\"radio\" name=\"system_area\" value=\"tracking\"> <span class=\"bp_signin_area_header\">&nbsp;Enter the <b><span style=\"color:#003399\">Tracking Area</span></b> to:</span>\n              <ul>\n                <li>Perform Editor-in-Chief duties</li>\n                <li>Perform Handling Editor duties</li>\n                <li>Perform Editorial Staff duties</li>\n              </ul>\n            </td>\n          </tr>\n        </tbody></table>\n      </form>\n    </div>\n    <table class=\"bp_signin_link_strip_base\" cellpadding=\"0\">\n      <tbody><tr>\n        <td width=\"*\" class=\"bp_dark_button\">\n          <a class=\"bp_dark_button\" href=\"/mic/\">Microbiology journal home</a>\n        </td>\n        <td width=\"*\" class=\"bp_dark_button\">\n          <a class=\"bp_dark_button\" href=\"/mic/misc/ifora.shtml\">Instructions for Authors</a>\n        </td>\n        <td width=\"*\" class=\"bp_dark_button\">\n          <a class=\"bp_dark_button\" href=\"/mic/misc/edboard.shtml\">Editorial Board</a>\n        </td>\n        <td class=\"bp_dark_button\" style=\"background-color:550000;width:75px;\">\n          <a class=\"bp_dark_button\" href=\"/mic/help/submissionhelp.dtl\">Help</a>\n        </td>\n        <td class=\"bp_dark_button\" style=\"background-color:550000;width:75px;\">\n          <a class=\"bp_dark_button\" href=\"/mic/cgi/feedback?name=+&amp;email=\">Feedback</a>\n        </td>\n      </tr>\n    </tbody></table>\n    <table class=\"bp_signin_address_footer\">\n      <tbody><tr>\n        <td align=\"center\"></td>\n        <td align=\"center\">\n          <a href=\"\"></a>\n        </td>\n        <td width=\"100%\" valign=\"middle\" class=\"bp_signin_text_small\" align=\"center\"><b>Microbiology</b><br>\n        Microbiology Editorial Office, Society for General Microbiology, Spencers Wood, Reading RG7 1AG, UK<br>\n        Tel: +44(0) 118 988 1800; Fax: +44(0) 118 988 1834; Email: micro@sgm.ac.uk</td>\n        <td align=\"center\"></td>\n        <td align=\"center\"></td>\n      </tr>\n    </tbody></table>\n    <table class=\"bp_signin_copyright_footer\">\n      <tbody><tr>\n        <td style=\"background:url(/icons/misc/curve_bl.gif) no-repeat bottom left;background-color:#333;width:19px;\"></td>\n        <td style=\"text-align:center;background-color:#333;width:562px;\"><span class=\"bp_signin_text_copyright\">© 2008 the Society for General Microbiology</span></td>\n        <td style=\"background:url(/icons/misc/curve_br.gif) no-repeat bottom right;background-color:#333;width:19px;\"></td>\n      </tr>\n    </tbody></table>\n  </div>"}