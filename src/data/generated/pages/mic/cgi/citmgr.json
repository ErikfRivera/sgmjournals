{"type":"info-page","slug":"mic/cgi/citmgr","journal":"mic","canonical":"https://www.sgmjournals.org/mic/cgi/citmgr","title":"Microbiology -- Download Directly to Citation Manager","bodyHtml":"<nobr><map name=\"home_button\" id=\"home_button\">\n    </map></nobr><nobr></nobr><nobr></nobr>\n    <area shape=\"rect\" coords=\"57,22,110,40\" href=\"/help/\">\n    <nobr></nobr>\n    <area shape=\"rect\" coords=\"0, 0,110,40\" href=\"/\">\n   <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/\"></a><br>\n  <nobr></nobr>\n  <table cellpadding=\"2\" cellspacing=\"2\" width=\"450\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">HOME</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/help/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">HELP</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/cgi/feedback\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">FEEDBACK</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/subscriptions\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SUBSCRIPTIONS</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/contents-by-date.0.shtml\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">ARCHIVE</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/search.dtl\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SEARCH</font></a>\n      </td>\n      <td width=\"75\" nowrap=\"\"></td>\n    </tr>\n  </tbody></table>\n  <hr width=\"450\" align=\"left\" noshade=\"\">\n  <p><strong><font size=\"+1\" face=\"verdana,arial,helvetica,sans-serif\">Download Directly to Citation Manager</font></strong></p>\n  <p><font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">Download the citation below by selecting one of the formats on the left (<strong><a href=\"#help\"><font color=\"#003399\">HELP</font></a></strong> is below):</font></p>\n  <p></p>\n  <table cellpadding=\"4\" cellspacing=\"0\" border=\"0\" width=\"450\">\n    <tbody><tr>\n      <td valign=\"top\">\n        <ul>\n          <li>\n            <font face=\"verdana,arial,helvetica,sans-serif\"><strong>EndNote</strong></font><br>\n            <font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">- EndNote format<br>\n            (Mac &amp; Win)</font>\n            <p></p>\n          </li>\n          <li>\n            <font face=\"verdana,arial,helvetica,sans-serif\"><strong>Reference<br>\n            <nobr>Manager</nobr></strong><nobr></nobr> *</font><br>\n            <font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">- Ris format<br>\n            (Win only)</font>\n            <p></p>\n          </li>\n          <li>\n            <font face=\"verdana,arial,helvetica,sans-serif\"><nobr><strong>ProCite</strong></nobr> *</font><br>\n            <font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">- Ris format<br>\n            (Mac &amp; Win)</font>\n            <p></p>\n          </li>\n          <li>\n            <font face=\"verdana,arial,helvetica,sans-serif\"><nobr><strong>BibTeX</strong></nobr></font><br>\n            <font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">- BibTeX format<br>\n            (Mac &amp; Win)</font>\n            <p></p>\n          </li>\n          <li>\n            <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">Medlars format</font>\n          </li>\n        </ul>\n      </td>\n      <td nowrap=\"\">&nbsp;&nbsp;&nbsp;</td>\n      <td valign=\"top\" bgcolor=\"#DBDBDB\"><font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\"></font></td>\n    </tr>\n    <tr>\n      <td></td>\n    </tr>\n    <tr>\n      <td colspan=\"4\" bgcolor=\"#DBDBDB\">\n        <a href=\"/mic/cgi/feedback\"><font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">Request an additional format be added to this list</font></a>\n      </td>\n    </tr>\n  </tbody></table>\n  <p><font face=\"verdana,arial,helvetica,sans-serif\">*</font> <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">WINDOWS ONLY: To automatically import into Reference Manager or ProCite, make sure to follow the instructions <a href=\"#refmanprocite\">below</a>.</font> <a name=\"help\" id=\"help\"></a></p>\n  <p></p>\n  <hr noshade=\"\" size=\"1\">\n  <p><strong><font size=\"+1\" face=\"verdana,arial,helvetica,sans-serif\" color=\"#003399\">Help with downloading citations using Netscape:</font></strong><br>\n  <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\"><a href=\"#all\">All formats</a>&nbsp;&nbsp;||&nbsp;&nbsp; <a href=\"#endnote\">EndNote</a>&nbsp;&nbsp;||&nbsp;&nbsp; <a href=\"#refmanprocite\">Reference Manager and ProCite</a></font></p>\n  <p><a name=\"all\" id=\"all\"></a> <strong><font face=\"verdana,arial,helvetica,sans-serif\">All formats:</font></strong></p>\n  <p></p>\n  <dl>\n    <dd>\n      <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">If you get an alert message when you click one of the above download links that begins <strong>You have started to download the file \"\" of type \"x-endnote-refer\"</strong> -or- <strong>... of type \"x-Research-Info_systems\"</strong>, -or- <strong>... of type \"octet-stream\"</strong>, click the 'Cancel' button and:</font>\n      <p></p>\n      <ol type=\"a\">\n        <li>\n          <font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">Go to the \"Edit/Preferences...\" menu and click on \"Navigator/Applications\"</font>\n          <p></p>\n        </li>\n        <li>\n          <font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">Scroll through the list looking for:</font>\n          <p></p>\n          <table cellpadding=\"4\" cellspacing=\"0\" border=\"1\" nowrap=\"\">\n            <tbody><tr>\n              <th width=\"25%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">EndNote</font></th>\n              <th width=\"25%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Reference Manager and ProCite</font></th>\n              <td valign=\"middle\" width=\"25%\" bgcolor=\"#DBDBDB\" align=\"center\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">generic</font></td>\n            </tr>\n            <tr>\n              <td valign=\"top\" width=\"25%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">'EndNote' or<br>\n              'application/x-endnote-refer'</font></td>\n              <td valign=\"top\" width=\"25%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">'application/x-Research-Info-Systems'</font></td>\n              <td valign=\"top\" width=\"25%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">'Binary Executable File' or<br>\n              'application/octet-stream'</font></td>\n            </tr>\n          </tbody></table>\n          <p><font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">If you find it:</font></p>\n          <ul>\n            <li><font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">Click on it and select 'Edit'.</font></li>\n            <li><font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">Select the 'Save to disk' radio button</font></li>\n          </ul><font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">Otherwise, continue to the next step:</font>\n          <p></p>\n        </li>\n        <li>\n          <font face=\"verdana,arial,helvetica,sans-serif\" size=\"-1\">If you didn't find an entry in the list from the previous step:<br>\n          Still in the 'Applications' section, select 'New' and enter the following values:</font>\n          <p></p>\n          <table cellpadding=\"4\" cellspacing=\"0\" border=\"1\" nowrap=\"\">\n            <tbody><tr>\n              <td width=\"20%\" bgcolor=\"#DBDBDB\">&nbsp;</td>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">EndNote</font></th>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Reference Manager and ProCite</font></th>\n              <td valign=\"middle\" width=\"20%\" bgcolor=\"#DBDBDB\" align=\"center\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">generic</font></td>\n            </tr>\n            <tr>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Description</font></th>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">EndNote Citation</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Reference Manager Citation (or) ProCite Citation</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Binary Executable File</font></td>\n            </tr>\n            <tr>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">MIME Type</font></th>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">application/x-endnote-refer</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">application/x-Research-Info-Systems</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">application/octet-stream</font></td>\n            </tr>\n            <tr>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Suffixes/File extension</font></th>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">enw</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">RIS</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">exe</font></td>\n            </tr>\n            <tr>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">File type<br>\n              (Mac only)</font></th>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">TEXT</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">TEXT</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">&nbsp;</font></td>\n            </tr>\n            <tr>\n              <th width=\"20%\" bgcolor=\"#DBDBDB\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Tell Netscape what to<br>\n              do with the citation</font></th>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Select the '<strong>Application</strong>' radio button or the 'Browse' button and browse to your copy of EndNote</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">MAC ONLY:<br>\n              Select the '<strong>Application</strong>' radio button and browse to your copy of Reference Manager or ProCite</font></td>\n              <td valign=\"top\" width=\"20%\"><font size=\"-2\" face=\"verdana,arial,helvetica,sans-serif\">Select the '<strong>Save to disk</strong>' radio button</font></td>\n            </tr>\n          </tbody></table>\n        </li>\n      </ol>\n    </dd>\n  </dl><a name=\"endnote\" id=\"endnote\"></a>\n  <p><strong><font face=\"verdana,arial,helvetica,sans-serif\">EndNote Only:</font></strong></p>\n  <p></p>\n  <ol>\n    <li>\n      <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">Make sure you have .</font>\n      <p></p>\n    </li>\n    <li>\n      <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">If you are able to download the file and EndNote launches automatically, but the citation doesn't get imported, reinstall the .</font>\n      <p></p>\n    </li>\n    <li>\n      <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">MAC ONLY: If you are able to download the file and EndNote launches automatically, but you get the error message \"This file is incompatible with this version of EndNote\", make sure that the 'file type' (in the General instructions above) is set to TEXT.</font>\n      <p></p>\n    </li>\n    <li><font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">If you are having other problems using EndNote, try reinstalling the .</font></li>\n  </ol><a name=\"refmanprocite\" id=\"refmanprocite\"></a>\n  <p><strong><font face=\"verdana,arial,helvetica,sans-serif\">Reference Manager and ProCite Only:</font></strong></p>\n  <p></p>\n  <ol>\n    <li>\n      <font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">WINDOWS ONLY: Is the citation opening Reference Manager or ProCite but not importing the citation? Make sure that you have installed . Follow the instructions and then restart your computer.</font>\n      <p></p>\n    </li>\n    <li><font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">PROCITE FOR MAC ONLY: If you get the error 'no records were found' when you try to transfer the citation into your database, make sure that you have selected the 'Ris' file format option.</font></li>\n  </ol>\n  <p></p>\n  <hr noshade=\"\" size=\"1\" color=\"#003399\">\n  <p></p>\n  <table cellpadding=\"0\" cellspacing=\"1\" border=\"0\" bgcolor=\"#003399\">\n    <tbody><tr>\n      <td>\n        <table cellpadding=\"5\" cellspacing=\"1\" border=\"0\" bgcolor=\"#FFFFFF\">\n          <tbody><tr>\n            <td><font size=\"-1\" face=\"verdana,arial,helvetica,sans-serif\">If you are having other problems downloading citations, please send us <a href=\"/mic/cgi/feedback\">feedback</a>.</font></td>\n          </tr>\n        </tbody></table>\n      </td>\n    </tr>\n  </tbody></table>\n  <p></p>\n  <hr noshade=\"\" align=\"left\" width=\"450\">\n  <table cellpadding=\"2\" cellspacing=\"2\" width=\"450\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">HOME</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/help/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">HELP</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/cgi/feedback\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">FEEDBACK</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/subscriptions\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SUBSCRIPTIONS</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/contents-by-date.0.shtml\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">ARCHIVE</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/mic/search.dtl\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">SEARCH</font></a>\n      </td>\n      <td width=\"75\" nowrap=\"\"></td>\n    </tr>\n  </tbody></table>\n  <table cellpadding=\"1\" cellspacing=\"2\" width=\"375\">\n    <tbody><tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/ijs/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">INT J SYST EVOL MICROBIOL</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#E1E1E1\" nowrap=\"\"><font size=\"-2\" color=\"#000000\" face=\"arial,helvetica\">MICROBIOLOGY</font></td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/vir/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">J GEN VIROL</font></a>\n      </td>\n    </tr>\n    <tr>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/jmm/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">J MED MICROBIOL</font></a>\n      </td>\n      <td align=\"center\" valign=\"top\" bgcolor=\"#003399\" nowrap=\"\" colspan=\"2\">\n        <a target=\"_top\" style=\"text-decoration: none\" href=\"/\"><font size=\"-2\" color=\"#FFFFFF\" face=\"arial,helvetica\">ALL SGM JOURNALS</font></a>\n      </td>\n    </tr>\n  </tbody></table><font size=\"-1\"><strong><a target=\"_top\" href=\"/mic/misc/terms.shtml\">Copyright © 2004 Society for General Microbiology.</a></strong></font>"}